# ============================================================
# CONFIGURAÇÃO GERAL
# ============================================================

START_DATE=2026-05-01
END_DATE=2026-05-31
MAX_JOBS=30

# ============================================================
# FILTROS DE VAGAS
# ============================================================

JOB_KEYWORDS=Analista e Desenvolvedor de Sistemas
JOB_LOCATION=Goiânia
REMOTE_ONLY=true

# ============================================================
# AGENDAMENTO
# ============================================================

RUN_SCHEDULE=0 8 * * *

# Todos os dias às 08:00

# ============================================================
# FONTE DE DADOS
# DATA_SOURCE: 'api' ou 'scraping'
# ============================================================

DATA_SOURCE=scraping

# -------- Providers de API --------
# API_PROVIDER: 'remotive' ou 'adzuna'
# API_PROVIDER=remotive

# Adzuna (obrigatório se API_PROVIDER=adzuna)
# ADZUNA_APP_ID=seu_app_id
# ADZUNA_APP_KEY=sua_app_key
# ADZUNA_COUNTRY=br

# -------- Providers de Scraping --------
# SCRAPING_PROVIDER: 'linkedin', 'infojobs' ou 'glassdoor'
SCRAPING_PROVIDER=linkedin

# ============================================================
# BANCO DE DADOS
# ============================================================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=jobs_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin